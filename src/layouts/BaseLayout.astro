---
import { buildAbsoluteUrl, siteConfig } from "../site-config";

interface Props {
	title: string;
	description: string;
	pathname?: string;
	ogType?: "website" | "article";
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
	footerLinks?: { href: string; label: string }[];
}

const {
	title,
	description,
	pathname = Astro.url.pathname,
	ogType = "website",
	noindex = !siteConfig.siteUrl,
	structuredData = [],
	footerLinks = []
} = Astro.props;

const canonicalUrl = buildAbsoluteUrl(pathname);
const socialImageUrl = buildAbsoluteUrl(siteConfig.socialCardPath);
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const sitemapHref = siteConfig.siteUrl ? "/sitemap-index.xml" : undefined;
const structuredDataEntries = Array.isArray(structuredData) ? structuredData : [structuredData];
const organizationSchema = canonicalUrl
	? {
			"@context": "https://schema.org",
			"@type": siteConfig.companyType,
			name: siteConfig.siteName,
			description: siteConfig.siteDescription,
			url: siteConfig.siteUrl,
			logo: buildAbsoluteUrl(siteConfig.brandMarkPath)
		}
	: undefined;

const schemaGraph = [organizationSchema, ...structuredDataEntries].filter(Boolean);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		<meta property="og:site_name" content={siteConfig.siteName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={siteConfig.locale} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{sitemapHref && <link rel="sitemap" href={sitemapHref} />}
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
		{socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
		<title>{title}</title>
		{
			schemaGraph.length > 0 && (
				<script
					type="application/ld+json"
					set:html={JSON.stringify(schemaGraph.length === 1 ? schemaGraph[0] : { "@context": "https://schema.org", "@graph": schemaGraph })}
				/>
			)
		}
		<style is:global>
			@import url("https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;700&display=swap");

			:root {
				--color-ink: #0f1720;
				--color-muted: #52606d;
				--color-paper: #f7f4ec;
				--color-panel: rgba(255, 255, 255, 0.74);
				--color-border: rgba(15, 23, 32, 0.12);
				--color-accent: #ef7d42;
				--color-accent-deep: #bc4728;
				--color-shadow: rgba(15, 23, 32, 0.08);
				--space-3: 0.75rem;
				--space-4: 1rem;
				--space-6: 1.5rem;
				--space-8: 2rem;
				--space-12: 3rem;
				--space-16: 4rem;
				--radius-l: 2rem;
				--shadow-soft: 0 24px 60px var(--color-shadow);
				--content-width: 72rem;
			}

			* {
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				margin: 0;
				font-family: "Space Grotesk", sans-serif;
				color: var(--color-ink);
				background:
					radial-gradient(circle at top left, rgba(239, 125, 66, 0.22), transparent 24rem),
					linear-gradient(180deg, #f3ecda 0%, var(--color-paper) 36%, #fdfbf6 100%);
				min-height: 100vh;
			}

			a {
				color: inherit;
			}

			.page-shell {
				width: min(calc(100% - 2rem), var(--content-width));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: var(--space-6) 0 var(--space-8);
				gap: var(--space-4);
			}

			.brand-lockup {
				display: inline-flex;
				align-items: center;
				gap: var(--space-3);
				text-decoration: none;
			}

			.brand-mark {
				width: 2.75rem;
				height: 2.75rem;
				border-radius: 1rem;
				display: grid;
				place-items: center;
				font-weight: 700;
				letter-spacing: 0.08em;
				background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-deep) 100%);
				color: white;
				box-shadow: var(--shadow-soft);
			}

			.brand-name {
				font-size: 0.95rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.site-nav {
				display: flex;
				gap: var(--space-4);
				flex-wrap: wrap;
			}

			.site-nav a {
				text-decoration: none;
				font-size: 0.95rem;
				color: var(--color-muted);
			}

			main {
				padding-bottom: var(--space-16);
			}

			.site-footer {
				padding: var(--space-8) 0 var(--space-12);
				color: var(--color-muted);
				font-size: 0.95rem;
			}

			.footer-links {
				display: flex;
				gap: var(--space-4);
				flex-wrap: wrap;
				margin-top: var(--space-4);
			}

			.footer-links a {
				text-decoration: none;
			}

			.skip-link {
				position: absolute;
				left: 1rem;
				top: -4rem;
				z-index: 10;
				padding: 0.75rem 1rem;
				border-radius: 999px;
				background: var(--color-ink);
				color: white;
				text-decoration: none;
			}

			.skip-link:focus {
				top: 1rem;
			}

			.legal-prose {
				background: var(--color-panel);
				backdrop-filter: blur(14px);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-l);
				box-shadow: var(--shadow-soft);
				padding: clamp(1.5rem, 2vw, 2.5rem);
			}

			.legal-prose h1,
			.legal-prose h2,
			.legal-prose h3 {
				font-family: "Instrument Serif", serif;
				font-weight: 400;
				line-height: 1;
				letter-spacing: -0.03em;
				margin: 0 0 var(--space-4);
			}

			.legal-prose h1 {
				font-size: clamp(2.75rem, 6vw, 4.75rem);
				margin-bottom: var(--space-6);
			}

			.legal-prose h2 {
				font-size: clamp(1.75rem, 3vw, 2.5rem);
				margin-top: var(--space-8);
			}

			.legal-prose p,
			.legal-prose li {
				color: var(--color-muted);
				font-size: 1rem;
				line-height: 1.7;
			}

			.legal-prose ul {
				padding-left: 1.25rem;
			}

			.eyebrow {
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-accent-deep);
				margin-bottom: var(--space-4);
			}

			@media (max-width: 720px) {
				.site-header {
					align-items: flex-start;
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<div class="page-shell">
			<a class="skip-link" href="#main-content">Skip to content</a>
			<header class="site-header">
				<a class="brand-lockup" href="/">
					<span class="brand-mark" aria-hidden="true">EB</span>
					<span class="brand-name">Eclectic Byte</span>
				</a>
				<nav class="site-nav" aria-label="Primary">
					<a href="/#studio">Studio</a>
					<a href="/#legal">Legal</a>
				</nav>
			</header>
			<main id="main-content">
				<slot />
			</main>
			<footer class="site-footer">
				<p>{siteConfig.siteTagline}</p>
				{
					footerLinks.length > 0 && (
						<nav class="footer-links" aria-label="Footer">
							{footerLinks.map((link) => (
								<a href={link.href}>{link.label}</a>
							))}
						</nav>
					)
				}
			</footer>
		</div>
	</body>
</html>
