---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteConfig, videoCompressorConfig } from "../../../site-config";
import documentHtml from "../../../../video-compressor/legal/privacy-policy.html?raw";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: `${videoCompressorConfig.productName} Privacy Policy`,
	description: videoCompressorConfig.privacyDescription,
	isPartOf: siteConfig.siteUrl || undefined
};
---

<BaseLayout
	title="Video Compressor Privacy Policy | Eclectic Byte"
	description="Privacy Policy for the Video Compressor product by Eclectic Byte."
	pathname="/video-compressor/legal/privacy-policy"
	ogType="article"
	structuredData={structuredData}
>
	<section>
		<p class="eyebrow">Video Compressor legal</p>
		<div class="legal-prose" set:html={documentHtml} />
	</section>
</BaseLayout>
