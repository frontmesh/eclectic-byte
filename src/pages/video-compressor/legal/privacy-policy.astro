---
import { readFileSync } from "node:fs";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const documentHtml = readFileSync("video-compressor/legal/privacy-policy.html", "utf-8");
---

<BaseLayout
	title="Video Compressor Privacy Policy | Eclectic Byte"
	description="Privacy Policy for the Video Compressor product by Eclectic Byte."
>
